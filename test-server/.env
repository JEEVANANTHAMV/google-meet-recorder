# ---- Server ----
PORT=8001
HOST=0.0.0.0
PUBLIC_BASE_URL=http://18.204.127.179:8001

# ---- Storage ----
# gcs (production) | local (dev/testing)
STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=meet-cloud
GCS_PROJECT_ID=betacrmerp
GCS_LOCATION=ASIA-SOUTH1
GOOGLE_APPLICATION_CREDENTIALS=./Service-Account.json
SIGNED_URL_EXPIRES_DAYS=7

# ---- WebSocket hardening ----
WS_MAX_PAYLOAD_MB=16
WS_HEARTBEAT_MS=15000
# Comma list; supports chrome-extension://<id> or "chrome-extension://*". Empty = allow all.
WS_ALLOWED_ORIGINS=
# Optional shared secret the extension must send in its auth message. Empty = no auth.
AUTH_TOKEN=

# ---- Misc ----
EVENT_FLUSH_MS=5000
CORS_ORIGIN=*
LOG_LEVEL=info
LOG_PRETTY=true
